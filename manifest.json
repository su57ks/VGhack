{
  "manifest_version": 3,
  "name": "WGhack by su57ks",
  "version": "1.0",
  "description": "Помогает легко выполнять задания на сайте ВебГрамотей. ВНИМАНИЕ: Сейчас проходит Бета-тестирование. Я не гарантирую правильность ответов.",
  "content_scripts": [
    {
      "matches": [
        "https://login.cerm.ru/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "answers.json"
      ],
      "matches": [
        "https://login.cerm.ru/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}